/* Configuración General */
body {
    background-color: #09090b; /* Negro profundo */
    color: #ffffff;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    margin: 0;
}

/* Estilo del Título Principal */
h1 {
    color: #f97316; /* Color Naranja Basketball */
    text-transform: uppercase;
    letter-spacing: -1px;
}

/* Diseño de las Tarjetas de Juegos */
.card {
    background-color: #18181b;
    border: 1px solid #27272a;
    border-radius: 15px;
    padding: 15px;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
}

/* Efecto cuando pasas el mouse por encima */
.card:hover {
    transform: translateY(-10px);
    border-color: #f97316;
    box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
}

/* Contenedor del Juego (el marco) */
.game-frame {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 2px solid #27272a;
    border-radius: 12px;
    background-color: #000;
}

/* Botón de Pantalla Completa */
.btn-full {
    background-color: #f97316;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
}

.btn-full:hover {
    background-color: #ea580c;
}
